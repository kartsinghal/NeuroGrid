PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# MongoDB Atlas URI — add your connection string here
MONGODB_ATLAS_URI=

# Local MongoDB fallback
MONGODB_LOCAL_URI=mongodb://127.0.0.1:27017/neurogrid

# DB mode: auto | atlas | local | memory
DB_MODE=auto

SIMULATION_AUTO_START=true
SIMULATION_SLOW_MODE=false
