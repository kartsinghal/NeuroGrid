# NeuroGrid AI — Environment Variables
# Copy this file to backend/.env and fill in values

# =============================================
# DATABASE CONFIGURATION
# =============================================

# MongoDB Atlas URI (production)
# Format: mongodb+srv://user:password@cluster.mongodb.net/neurogrid
MONGODB_ATLAS_URI=

# Local MongoDB URI (fallback)
MONGODB_LOCAL_URI=mongodb://127.0.0.1:27017/neurogrid

# Database selection: 'atlas' | 'local' | 'memory'
# 'memory' forces in-memory mode regardless of DB availability
DB_MODE=auto

# =============================================
# SERVER CONFIGURATION
# =============================================

PORT=5000
NODE_ENV=development

# CORS origin (frontend URL)
CORS_ORIGIN=http://localhost:5173

# =============================================
# SIMULATION CONFIGURATION
# =============================================

# Enable automatic simulation on startup
SIMULATION_AUTO_START=true

# Slow mode for demos (increases tick interval)
SIMULATION_SLOW_MODE=false

# =============================================
# FRONTEND (Vite env vars must start with VITE_)
# =============================================
# Put these in frontend/.env

VITE_BACKEND_URL=http://localhost:5000
VITE_APP_NAME=NeuroGrid AI
